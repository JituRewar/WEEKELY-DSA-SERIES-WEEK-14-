#include <bits/stdc++.h>
using namespace std;

class Graph
{
    int V;
    list<int> *l; // for dynamic we use pointer like (int* arr)

public:
    Graph(int V)
    {
        this->V = V;
        // arr = new int[v]
        l = new list<int>[V];
    }

    void addEdge(int u, int v)
    { // for undirectional graph
        l[u].push_back(v);
        l[v].push_back(u);
    }

    void pritnVer(){
        for (int i = 0; i < V; i++)
        {
            cout<< i << " : ";
            for(int neigh : l[i]){
                cout<< neigh << " ";
            }
            cout<<endl;
        }
        
    }
};

int main()
{
    Graph g(5);
    g.addEdge(0,1);
    g.addEdge(1,2);
    g.addEdge(1,3);
    g.addEdge(2,3);
    g.addEdge(2,4);
    g.pritnVer();
    return 0;
}

